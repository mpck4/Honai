# Copy to .env and fill in values before running any agent script.
# Run scripts from this directory: cd agents && python triage.py

# Path to sessions.db written by Charlie's ingest/tail.py
DB_PATH=/data/sessions.db

# Groq API key — free tier at console.groq.com
GROQ_API_KEY=gsk_...

# Telegram bot credentials
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_TOKEN=...
TELEGRAM_CHAT_ID=...

# Optional: how often triage.py polls for new sessions (default 10s)
# POLL_INTERVAL=10
