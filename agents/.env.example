# Copy to agents/.env and fill in values before `docker compose up`.
# Docker compose loads this file into the triage container.

# Groq API key — free tier at console.groq.com
GROQ_API_KEY=gsk_...

# Telegram bot credentials
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_TOKEN=...
TELEGRAM_CHAT_ID=...

# Optional: how often triage polls for new sessions (default 10s)
# POLL_INTERVAL=10

# Optional: override the DB path. Defaults to /data/sessions.db inside the
# container, which maps to ./data/sessions.db on the host via the compose
# volume. Only set this if you're running triage.py outside Docker.
# DB_PATH=/data/sessions.db
